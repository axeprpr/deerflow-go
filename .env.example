# LLM Configuration
SILICONFLOW_API_KEY=sk-your-key-here
# Canonical provider env var names:
# OPENAI_API_KEY=
# OPENAI_API_BASE_URL=
# ANTHROPIC_API_KEY=
DEFAULT_LLM_MODEL=qwen/Qwen3.5-9B
# Optional model catalog for the UI and model selector.
# Supports either a comma-separated list:
# DEERFLOW_MODELS=qwen/Qwen3.5-9B,deepseek/deepseek-r1
# Or a JSON array:
# DEERFLOW_MODELS=[{"name":"flash","model":"qwen/Qwen3.5-9B","display_name":"Flash"},{"name":"pro","model":"deepseek/deepseek-r1","display_name":"Pro","supports_thinking":true,"supports_reasoning_effort":true}]
# Optional additional skill directories, comma-separated.
# DEERFLOW_SKILLS_DIRS=/opt/deerflow/skills/public,/opt/deerflow/skills/custom
# Optional MCP config JSON for the embedded tools settings page.
# DEERFLOW_MCP_CONFIG={"mcp_servers":{"filesystem":{"enabled":true,"type":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem"],"description":"File system access"}}}
# Optional memory config JSON.
# DEERFLOW_MEMORY_CONFIG={"enabled":true,"debounce_seconds":30,"max_facts":100,"fact_confidence_threshold":0.7,"injection_enabled":true,"max_injection_tokens":2000}
# Optional explicit memory file path.
# DEERFLOW_MEMORY_PATH=/tmp/deerflow-go/memory.json
# Optional channels status/config JSON.
# DEERFLOW_CHANNELS_CONFIG={"service_running":true,"channels":{"telegram":{"enabled":true,"connected":false}}}

# Database (optional)
DATABASE_URL=sqlite:///tmp/deerflow-go/deerflow.db
# Legacy Postgres example:
# POSTGRES_URL=postgres://postgres:password@localhost:5432/deerflow?sslmode=disable

# Server
PORT=8080
LOG_LEVEL=info

# Sandbox
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT=60s
