{
  "name": "deerflow-go-electron",
  "version": "0.1.0",
  "description": "Deerflow Go desktop shell",
  "private": true,
  "type": "module",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/axeprpr/deerflow-go.git"
  },
  "author": "deerflow-go",
  "license": "MIT",
  "scripts": {
    "build:runtime": "node scripts/build-runtime.mjs",
    "dev": "electron .",
    "start": "electron .",
    "pack": "pnpm build:runtime && electron-builder --dir --publish never",
    "dist": "pnpm build:runtime && electron-builder --publish never",
    "dist:linux": "pnpm build:runtime && electron-builder --linux AppImage tar.gz --publish never",
    "dist:mac": "pnpm build:runtime && electron-builder --mac dmg zip --publish never",
    "dist:win": "pnpm build:runtime && electron-builder --win nsis zip --publish never"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.deerflow.go.desktop",
    "productName": "DeerFlow Go",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "runtime/bin",
        "to": "runtime/bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "artifactName": "deerflow-go-desktop-${version}-${os}-${arch}.${ext}",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Development"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  }
}
